# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def mergeTwoLists(self, list1: Optional[ListNode], list2: Optional[ListNode]) -> Optional[ListNode]:
        # Creating a placeholder node to act as the start of the merged list.
        placeholder = ListNode(0)

        # Current points to last node in merged list.
        current = placeholder

        # Loop while both lists have nodes.
        while list1 and list2:
            
            # Compare values of current nodes
            if list1.val < list2.val:
                # Attach the smaller node (from list1) to the merged list
                current.next = list1
                
                # Move list1 forward
                list1 = list1.next
            else:
                # Attach the smaller node (from list2) to the merged list
                current.next = list2
                
                # Move list2 forward
                list2 = list2.next
            
            # Move current foward
            current = current.next
        
        # At this point, one list may still have remaining nodes
        # Attach the remaining nodes directly (they are already sorted)
        if list1:
            current.next = list1
        else:
            current.next = list2

        # Return the merged list, skipping the placeholder node
        return placeholder.next

